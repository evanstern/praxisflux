{
  "name": "educate",
  "version": "0.2.0",
  "private": true,
  "description": "Claude plugin: turn any folder into a Socratic learning project.",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "selfbuild": "node scripts/make-plugin.mjs --out /tmp/educate-generated",
    "package": "rm -f /tmp/educate.plugin && zip -r /tmp/educate.plugin . -x '*.git*' '*node_modules*' '*-generated*' '*.DS_Store' && echo 'built /tmp/educate.plugin'"
  }
}
