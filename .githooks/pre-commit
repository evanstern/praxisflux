#!/usr/bin/env bash
# praxisflux pre-commit — keep the suite green and the catalog honest before every commit.
# Enable once with:  git config core.hooksPath .githooks
set -e
repo="$(git rev-parse --show-toplevel)"
cd "$repo"
echo "pre-commit: node --test"
# In a worktree checkout, git hands hooks an ABSOLUTE GIT_DIR; the suite's fixture repos
# (execFileSync git with cwd=tmpdir) would inherit it and commit onto the real branch.
# Scrub the hook env so the fixtures stay hermetic wherever the suite runs from.
env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE node --test
echo "pre-commit: marketplace.json up to date"
node scripts/gen-marketplace.mjs --check
echo "pre-commit: versions consistent"
node scripts/sync-version.mjs --check
echo "pre-commit: README/CLAUDE.md in sync"
node scripts/check-docs.mjs
