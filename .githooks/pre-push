#!/usr/bin/env bash
# praxisflux pre-push — don't push released-surface changes without a version bump.
# Local mirror of the CI gate (ci.yml runs the same script); CI stays authoritative
# because core.hooksPath is per-clone. Enable once with:
#   git config core.hooksPath .githooks
set -e
repo="$(git rev-parse --show-toplevel)"
cd "$repo"
echo "pre-push: version bump check vs origin/main"
node scripts/check-version-bump.mjs --base origin/main
echo "pre-push: grounding wiki freshness"
node grounding-wiki/gates/cli.mjs freshness . docs/wiki
